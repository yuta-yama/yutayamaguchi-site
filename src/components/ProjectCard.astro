---
interface Props {
  href: string;
  title: string;
  cover?: string;
  meta?: string;
}

const { href, title, cover, meta } = Astro.props;
// Cache-bust so CDN/browsers don't keep pre-fix thumbnail files
const coverSrc = cover ? `${cover}?v=2` : "";
---

<a class="card" href={href}>
  <div class="card-media">
    {
      coverSrc ? (
        <img src={coverSrc} alt={title} loading="lazy" decoding="async" />
      ) : (
        <div style="width:100%;height:100%;background:linear-gradient(135deg,#ddd8cf,#c9bfb2)" />
      )
    }
  </div>
  <div class="card-body">
    <h2 class="card-title">{title}</h2>
    {meta && <p class="card-meta">{meta}</p>}
  </div>
</a>
